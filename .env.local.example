# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Resend (https://resend.com) API key, used by app/api/contact/route.ts
# to send contact form submissions by email.
RESEND_API_KEY=

# Email address that receives contact form submissions.
CONTACT_TO_EMAIL=info@fleetarabia.com

# "From" address for outgoing mail. Must be a domain verified in Resend
# (Resend's onboarding@resend.dev works for testing before you verify
# your own domain).
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# Leave blank to disable analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Public site URL used for metadata, sitemap.xml and robots.txt.
NEXT_PUBLIC_SITE_URL=https://www.fleetarabia.com
